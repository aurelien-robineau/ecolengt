# MongoDB — local: `pnpm docker:db` then mongodb://127.0.0.1/ecolengt
# Production: MongoDB Atlas connection string (mongodb+srv://...)
DATABASE_URL=mongodb://127.0.0.1/ecolengt

# Random secret — generate with: openssl rand -hex 32
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Public site URL (required in production for Payload admin links and reset emails)
# Example: https://ecolengt.vercel.app
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Resend — password reset emails
# https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=no-reply@ecolengt.com
EMAIL_FROM_NAME=École de Batterie NGT

# Vercel Blob — set automatically when Blob storage is enabled on Vercel.
# Optional locally if you want to test cloud uploads.
# BLOB_READ_WRITE_TOKEN=
